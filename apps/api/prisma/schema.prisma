generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String           @id @default(cuid())
  email        String           @unique
  passwordHash String
  createdAt    DateTime         @default(now())
  applications JobApplication[]

  @@map("users")
}

model JobApplication {
  id            String       @id @default(cuid())
  companyName   String
  positionTitle String
  roleType      RoleType
  locationType  LocationType
  outcome       Outcome      @default(APPLIED)
  dateApplied   DateTime
  interviewDate DateTime?
  salaryMin     Float?
  salaryMax     Float?
  salaryType    SalaryType?
  contactName   String?
  contactInfo   String?
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  userId        String
  user          User        @relation(fields: [userId], references: [id])

  @@map("job_applications")
}

enum RoleType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum LocationType {
  ON_SITE
  HYBRID
  REMOTE
}

enum SalaryType {
  ANNUAL
  HOURLY
}

enum Outcome {
  APPLIED
  PHONE_SCREEN
  INTERVIEW_SCHEDULED
  INTERVIEW_COMPLETED
  OFFER_RECEIVED
  OFFER_ACCEPTED
  REJECTED
  WITHDRAWN
  NO_RESPONSE
  GHOSTED
}
